{
  "name": "Google Antigravity & Python Engine",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11",
      "installTools": true
    }
  },
  "remoteEnv": {
    // Forwards your local/repository secrets into the terminal environment
    "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}",
    "GOOGLE_APPLICATION_CREDENTIALS": "${localEnv:GOOGLE_APPLICATION_CREDENTIALS}",
    "PATH": "/home/vscode/.local/bin:${containerEnv:PATH}"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "python.terminal.activateEnvInTerminal": true
      },
      "extensions": [
        "ms-python.python"
      ]
    }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh"
}